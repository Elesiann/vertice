VITE_API_URL=http://localhost:3333
VITE_SENTRY_DSN=
VITE_SENTRY_REPLAY=false
VITE_SENTRY_TRACES_SAMPLE_RATE=
VITE_BUILD_SOURCEMAP=false
# Release identifier sent to Sentry. Cloudflare Pages auto-populates
# CF_PAGES_COMMIT_SHA, which vite.config.ts uses as a fallback when this is
# empty. Set explicitly in CI for non-Pages builds.
VITE_APP_VERSION=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
