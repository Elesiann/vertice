# Cloudflare Pages headers — applied to every response served by Pages.
# Reference: https://developers.cloudflare.com/pages/configuration/headers/
#
# IMPORTANT: connect-src lists the production API origin (api.vertice.cards,
# bound to the Workers deployment) and the Sentry + Cloudflare Insights
# endpoints. If the API host changes, update both `connect-src` here and the
# VITE_API_URL env var on Cloudflare Pages. The Sentry ingest host is scoped
# to *.sentry.io; tighten to the specific ingest subdomain if you know it
# (e.g. https://o123.ingest.us.sentry.io).

/*
  Content-Security-Policy: default-src 'self'; script-src 'self' 'sha256-6HlHLFp+AXwW8lxjNTnyZKAdtpfKA9JZqqMlyJYdQpE=' https://static.cloudflareinsights.com; style-src 'self' 'unsafe-inline'; font-src 'self'; img-src 'self' data: https://vertice.cards; connect-src 'self' https://api.vertice.cards https://*.sentry.io https://*.ingest.sentry.io https://*.ingest.us.sentry.io https://cloudflareinsights.com; frame-ancestors 'none'; form-action 'self'; base-uri 'self'; object-src 'none'; upgrade-insecure-requests
  Referrer-Policy: strict-origin-when-cross-origin
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Permissions-Policy: camera=(), microphone=(), geolocation=(), payment=(), usb=(), magnetometer=(), gyroscope=(), accelerometer=()
  Strict-Transport-Security: max-age=63072000; includeSubDomains; preload
  Cross-Origin-Opener-Policy: same-origin
  Cross-Origin-Resource-Policy: same-origin

# Long-lived caching for fingerprinted assets emitted by Vite.
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# Card images change rarely; cache aggressively but allow revalidation.
/card-images/*
  Cache-Control: public, max-age=2592000, stale-while-revalidate=86400

# HTML must always revalidate so deploys take effect immediately.
# Covers the SPA shell + every prerendered route (home, static, /cards/:id).
/
  Cache-Control: public, max-age=0, must-revalidate

/index.html
  Cache-Control: public, max-age=0, must-revalidate

/input
  Cache-Control: public, max-age=0, must-revalidate

/sobre
  Cache-Control: public, max-age=0, must-revalidate

/privacidade
  Cache-Control: public, max-age=0, must-revalidate

/termos
  Cache-Control: public, max-age=0, must-revalidate

/cards/*
  Cache-Control: public, max-age=0, must-revalidate
